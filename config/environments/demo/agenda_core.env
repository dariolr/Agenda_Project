# ACTIVE = usata oggi in runtime/build/deploy
# RESERVED = definita per compatibilita futura/guardrail, non usata da feature attive

# ACTIVE
APP_ENV=demo
API_BASE_URL=https://demo-api.romeolab.it
FRONTEND_URL=https://demo-prenota.romeolab.it
BACKEND_URL=https://demo-gestionale.romeolab.it
CORS_ALLOWED_ORIGINS=https://demo-prenota.romeolab.it,https://demo-gestionale.romeolab.it,http://localhost:8080
APP_TIMEZONE=Europe/Rome
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=agenda_demo
DB_USERNAME=agenda_demo_user
DB_PASSWORD=__SET_ME__
ALLOW_REAL_EMAILS=false
ALLOW_REAL_PAYMENTS=false
ALLOW_EXTERNAL_WEBHOOKS=false
ALLOW_DESTRUCTIVE_BUSINESS_ACTIONS=false
ALLOW_REAL_EXPORTS=false
SHOW_DEMO_BANNER=true
BILLING_DEFAULT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://demo-gestionale.romeolab.it/altro/abbonamento?billing=success
STRIPE_CANCEL_URL=https://demo-gestionale.romeolab.it/altro/abbonamento?billing=cancel
STRIPE_PORTAL_RETURN_URL=https://demo-gestionale.romeolab.it/altro/abbonamento
ONLINE_PAYMENTS_DEFAULT_PROVIDER=stripe
STRIPE_ONLINE_PAYMENTS_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_CONNECT_REFRESH_URL=https://demo-gestionale.romeolab.it/altro/pagamenti-online?provider=stripe&onboarding=refresh
STRIPE_CONNECT_RETURN_URL=https://demo-gestionale.romeolab.it/altro/pagamenti-online?provider=stripe&onboarding=return
STRIPE_ONLINE_PAYMENT_SUCCESS_URL=https://demo-prenota.romeolab.it/{slug}/payment-result?status=success
STRIPE_ONLINE_PAYMENT_CANCEL_URL=https://demo-prenota.romeolab.it/{slug}/payment-result?status=cancel
PAYPAL_PARTNER_CLIENT_ID=
PAYPAL_PARTNER_CLIENT_SECRET=
PAYPAL_PARTNER_MERCHANT_ID=
PAYPAL_WEBHOOK_ID=
PAYPAL_ONLINE_PAYMENT_SUCCESS_URL=https://demo-prenota.romeolab.it/booking/payment-result?status=success
PAYPAL_ONLINE_PAYMENT_CANCEL_URL=https://demo-prenota.romeolab.it/booking/payment-result?status=cancel

# RESERVED
ALLOW_REAL_WHATSAPP=false
ALLOW_PLAN_CHANGES=false
DEMO_RESET_EXPECTED=true
DEMO_AUTO_LOGIN_ENABLED=false
