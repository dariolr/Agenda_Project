APP_ENV=demo
API_BASE_URL=https://demo-api.romeolab.it
WEB_BASE_URL=https://demo-prenota.romeolab.it
CORS_ALLOWED_ORIGINS=https://demo-prenota.romeolab.it,https://demo-gestionale.romeolab.it
APP_TIMEZONE=Europe/Rome
DB_HOST=127.0.0.1
DB_PORT=3306
