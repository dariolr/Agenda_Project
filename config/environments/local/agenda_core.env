# ACTIVE = usata oggi in runtime/build/deploy
# RESERVED = definita per compatibilita futura/guardrail, non usata da feature attive

# ACTIVE
APP_ENV=local
API_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
APP_TIMEZONE=Europe/Rome
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=agenda_local
DB_USERNAME=root
DB_PASSWORD=
ALLOW_REAL_EMAILS=false
ALLOW_REAL_PAYMENTS=false
ALLOW_EXTERNAL_WEBHOOKS=false
ALLOW_DESTRUCTIVE_BUSINESS_ACTIONS=false
ALLOW_REAL_EXPORTS=false
SHOW_DEMO_BANNER=false
BILLING_DEFAULT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3001/altro/abbonamento?billing=success
STRIPE_CANCEL_URL=http://localhost:3001/altro/abbonamento?billing=cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:3001/altro/abbonamento
ONLINE_PAYMENTS_DEFAULT_PROVIDER=stripe
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_CONNECT_REFRESH_URL=http://localhost:3001/altro/pagamenti-online?provider=stripe&onboarding=refresh
STRIPE_CONNECT_RETURN_URL=http://localhost:3001/altro/pagamenti-online?provider=stripe&onboarding=return
STRIPE_ONLINE_PAYMENT_SUCCESS_URL=http://localhost:3000/{slug}/payment-result?status=success
STRIPE_ONLINE_PAYMENT_CANCEL_URL=http://localhost:3000/{slug}/payment-result?status=cancel
PAYPAL_PARTNER_CLIENT_ID=
PAYPAL_PARTNER_CLIENT_SECRET=
PAYPAL_PARTNER_MERCHANT_ID=
PAYPAL_WEBHOOK_ID=
PAYPAL_ONLINE_PAYMENT_SUCCESS_URL=http://localhost:3000/booking/payment-result?status=success
PAYPAL_ONLINE_PAYMENT_CANCEL_URL=http://localhost:3000/booking/payment-result?status=cancel

# RESERVED
ALLOW_REAL_WHATSAPP=false
ALLOW_PLAN_CHANGES=false
DEMO_RESET_EXPECTED=false
DEMO_AUTO_LOGIN_ENABLED=false
