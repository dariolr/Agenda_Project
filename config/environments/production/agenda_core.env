# ACTIVE = usata oggi in runtime/build/deploy
# RESERVED = definita per compatibilita futura/guardrail, non usata da feature attive

# ACTIVE
APP_ENV=production
API_BASE_URL=https://api.romeolab.it
FRONTEND_URL=https://prenota.romeolab.it
BACKEND_URL=https://gestionale.romeolab.it
CORS_ALLOWED_ORIGINS=https://prenota.romeolab.it,https://gestionale.romeolab.it
APP_TIMEZONE=Europe/Rome
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=agenda_production
DB_USERNAME=agenda_prod_user
DB_PASSWORD=__SET_ME__
ALLOW_REAL_EMAILS=true
ALLOW_REAL_PAYMENTS=true
ALLOW_EXTERNAL_WEBHOOKS=true
ALLOW_DESTRUCTIVE_BUSINESS_ACTIONS=true
ALLOW_REAL_EXPORTS=true
SHOW_DEMO_BANNER=false
BILLING_DEFAULT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://gestionale.romeolab.it/altro/abbonamento?billing=success
STRIPE_CANCEL_URL=https://gestionale.romeolab.it/altro/abbonamento?billing=cancel
STRIPE_PORTAL_RETURN_URL=https://gestionale.romeolab.it/altro/abbonamento
ONLINE_PAYMENTS_DEFAULT_PROVIDER=stripe
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_CONNECT_ONBOARDING_URL=https://gestionale.romeolab.it/altro/pagamenti-online?from_altro=1
STRIPE_ONLINE_PAYMENT_SUCCESS_URL=https://prenota.romeolab.it/{slug}/payment-result?status=success
STRIPE_ONLINE_PAYMENT_CANCEL_URL=https://prenota.romeolab.it/{slug}/payment-result?status=cancel
PAYPAL_PARTNER_CLIENT_ID=
PAYPAL_PARTNER_CLIENT_SECRET=
PAYPAL_PARTNER_MERCHANT_ID=
PAYPAL_WEBHOOK_ID=
PAYPAL_ONLINE_PAYMENT_SUCCESS_URL=https://prenota.romeolab.it/booking/payment-result?status=success
PAYPAL_ONLINE_PAYMENT_CANCEL_URL=https://prenota.romeolab.it/booking/payment-result?status=cancel

# RESERVED
ALLOW_REAL_WHATSAPP=true
ALLOW_PLAN_CHANGES=true
DEMO_RESET_EXPECTED=false
DEMO_AUTO_LOGIN_ENABLED=false
