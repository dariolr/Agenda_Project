# ACTIVE = usata oggi in runtime/build/deploy
# RESERVED = definita per compatibilita futura/guardrail, non usata da feature attive

# ACTIVE
APP_ENV=staging
DEMO_MODE=false
API_BASE_URL=https://staging-api.romeolab.it
FRONTEND_URL=https://staging-gestionale.romeolab.it
ALLOW_REAL_EMAILS=false
ALLOW_REAL_WHATSAPP=false
ALLOW_REAL_PAYMENTS=true
ALLOW_EXTERNAL_WEBHOOKS=true
ALLOW_DESTRUCTIVE_BUSINESS_ACTIONS=false
ALLOW_REAL_EXPORTS=false
SHOW_DEMO_BANNER=false

# RESERVED
ALLOW_PLAN_CHANGES=false
DEMO_RESET_EXPECTED=false
DEMO_AUTO_LOGIN_ENABLED=false
