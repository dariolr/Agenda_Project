APP_ENV=staging
API_BASE_URL=https://staging-api.romeolab.it
WEB_BASE_URL=https://staging-prenota.romeolab.it
CORS_ALLOWED_ORIGINS=https://staging-prenota.romeolab.it,https://staging-gestionale.romeolab.it
APP_TIMEZONE=Europe/Rome
DB_HOST=127.0.0.1
DB_PORT=3306
