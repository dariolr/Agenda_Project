# Environment
APP_ENV=production
APP_DEBUG=false
APP_BASE_PATH=

# Database
DB_HOST=127.0.0.1
DB_PORT=8889
DB_DATABASE=agenda_core
DB_USERNAME=root
DB_PASSWORD=root    

# JWT
JWT_SECRET=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=864000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:54408,http://127.0.0.1:54408

# Timezone
APP_TIMEZONE=Europe/Rome
DEFAULT_LOCALE=it

# ========================================
# EMAIL NOTIFICATIONS
# ========================================

# Email - Siteground
MAIL_PROVIDER=smtp
MAIL_FROM_ADDRESS=noreply@romeolab.it
MAIL_FROM_NAME="Gestionale Appuntamenti"
REMINDER_MIN_HOURS_BEFORE_START=2
REMINDER_MAX_HOURS_BEFORE_START= 25
# SMTP Configuration (SiteGround)
SMTP_HOST=mail.romeolab.it
SMTP_PORT=465
SMTP_USERNAME=noreply@romeolab.it
SMTP_PASSWORD=your-email-password
SMTP_ENCRYPTION=ssl
EMAIL_SMTP_ONLY=true
ALLOW_PHP_MAIL_FALLBACK=false
# BREVO
MAIL_FALLBACK_PROVIDER=brevo
BREVO_API_KEY=your-brevo-api-key

MAIL_FROM_ADDRESS_BOOKING_CONFIRMED=noreply@romeolab.it
MAIL_FROM_ADDRESS_BOOKING_REMINDER=noreply@romeolab.it
MAIL_FROM_ADDRESS_BOOKING_CANCELLED=noreply@romeolab.it
MAIL_FROM_ADDRESS_BOOKING_RESCHEDULED=noreply@romeolab.it

FRONTEND_URL=https://prenota.romeolab.it
BACKEND_URL=https://gestionale.romeolab.it
API_BASE_URL=https://api.romeolab.it

ALLOW_REAL_EMAILS=true
ALLOW_REAL_WHATSAPP=true
ALLOW_REAL_PAYMENTS=true
ALLOW_EXTERNAL_WEBHOOKS=true
ALLOW_DESTRUCTIVE_BUSINESS_ACTIONS=true
ALLOW_PLAN_CHANGES=true
ALLOW_REAL_EXPORTS=true

SHOW_DEMO_BANNER=false
DEMO_RESET_EXPECTED=false
DEMO_AUTO_LOGIN_ENABLED=false

# Test mode: redirect all notification emails to nome.cognome@romeolab.it
NOTIFICATION_TEST_MODE=false
NOTIFICATION_TEST_EMAIL=dariolarosa@hotmail.com
