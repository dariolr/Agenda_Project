# ========================================
# EMAIL NOTIFICATIONS
# ========================================

# Email - Siteground
MAIL_PROVIDER=smtp
MAIL_FROM_ADDRESS=noreply@romeolab.it
MAIL_FROM_NAME="Gestionale Appuntamenti"
# SMTP Configuration (SiteGround)
SMTP_HOST=mail.romeolab.it
SMTP_PORT=465
SMTP_USERNAME=noreply@romeolab.it
SMTP_PASSWORD=your-email-password
SMTP_ENCRYPTION=ssl
EMAIL_SMTP_ONLY=true
ALLOW_PHP_MAIL_FALLBACK=false
# BREVO
MAIL_FALLBACK_PROVIDER=brevo
BREVO_API_KEY=your-brevo-api-key

MAIL_FROM_ADDRESS_BOOKING_CONFIRMED=noreply@romeolab.it
MAIL_FROM_ADDRESS_BOOKING_REMINDER=noreply@romeolab.it
MAIL_FROM_ADDRESS_BOOKING_CANCELLED=noreply@romeolab.it
MAIL_FROM_ADDRESS_BOOKING_RESCHEDULED=noreply@romeolab.it

FRONTEND_URL=https://demo-prenota.romeolab.it
BACKEND_URL=https://demo-gestionale.romeolab.it
API_BASE_URL=https://demo-api.romeolab.it

ALLOW_REAL_EMAILS=false
ALLOW_REAL_WHATSAPP=false
ALLOW_REAL_PAYMENTS=false
ALLOW_EXTERNAL_WEBHOOKS=false
ALLOW_DESTRUCTIVE_BUSINESS_ACTIONS=false
ALLOW_PLAN_CHANGES=false
ALLOW_REAL_EXPORTS=false

SHOW_DEMO_BANNER=true
DEMO_RESET_EXPECTED=true
DEMO_AUTO_LOGIN_ENABLED=false

# Test mode: redirect all notification emails to nome.cognome@romeolab.it
NOTIFICATION_TEST_MODE=true
NOTIFICATION_TEST_EMAIL=dariolarosa@hotmail.com
