# Environment
APP_ENV=demo
APP_DEBUG=true
APP_BASE_PATH=

# Database
DB_HOST=127.0.0.1
DB_PORT=8889
DB_DATABASE=agenda_demo
DB_USERNAME=root
DB_PASSWORD=root    

# JWT
JWT_SECRET=yIj68hqcXf1utipfQvD+BZvHKpxwWq+DkEhMLmyg4GaTfAiBDjVABP00uZzHnMQZrSsAw1OLlNYNSegb+ddQ1A==
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=864000

# CORS
CORS_ALLOWED_ORIGINS=https://demo-prenota.romeolab.it,https://demo-gestionale.romeolab.it

# Timezone
APP_TIMEZONE=Europe/Rome
DEFAULT_LOCALE=it

# ========================================
# EMAIL NOTIFICATIONS
# ========================================

# Email - Siteground
MAIL_PROVIDER=smtp
MAIL_FROM_ADDRESS=noreply@romeolab.it
MAIL_FROM_NAME="Gestionale Appuntamenti"
REMINDER_MIN_HOURS_BEFORE_START=2
REMINDER_MAX_HOURS_BEFORE_START=25
REMINDER_FETCH_LOOKAHEAD_HOURS=3
# SMTP Configuration (SiteGround)
SMTP_HOST=mail.romeolab.it
SMTP_PORT=465
SMTP_USERNAME=noreply@romeolab.it
SMTP_PASSWORD=your-email-password
SMTP_ENCRYPTION=ssl
EMAIL_SMTP_ONLY=true
ALLOW_PHP_MAIL_FALLBACK=false
# BREVO
MAIL_FALLBACK_PROVIDER=brevo
BREVO_API_KEY=your-brevo-api-key

MAIL_FROM_ADDRESS_BOOKING_CONFIRMED=noreply@romeolab.it
MAIL_FROM_ADDRESS_BOOKING_REMINDER=noreply@romeolab.it
MAIL_FROM_ADDRESS_BOOKING_CANCELLED=noreply@romeolab.it
MAIL_FROM_ADDRESS_BOOKING_RESCHEDULED=noreply@romeolab.it

FRONTEND_URL=https://demo-prenota.romeolab.it
BACKEND_URL=https://demo-gestionale.romeolab.it
API_BASE_URL=https://demo-api.romeolab.it

BILLING_DEFAULT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://demo-gestionale.romeolab.it/altro/abbonamento?billing=success
STRIPE_CANCEL_URL=https://demo-gestionale.romeolab.it/altro/abbonamento?billing=cancel
STRIPE_PORTAL_RETURN_URL=https://demo-gestionale.romeolab.it/altro/abbonamento

ALLOW_REAL_EMAILS=false
ALLOW_REAL_WHATSAPP=false
ALLOW_REAL_PAYMENTS=false
ALLOW_EXTERNAL_WEBHOOKS=false
ALLOW_DESTRUCTIVE_BUSINESS_ACTIONS=false
ALLOW_PLAN_CHANGES=false
ALLOW_REAL_EXPORTS=false

SHOW_DEMO_BANNER=true
DEMO_RESET_EXPECTED=true
DEMO_AUTO_LOGIN_ENABLED=false

# ========================================
# WHATSAPP BUSINESS (META EMBEDDED SIGNUP)
# ========================================
WHATSAPP_EMBEDDED_SIGNUP_DEFAULT_ENABLED=false
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me
WHATSAPP_TOKEN_ENCRYPTION_KEY=change-me-32-bytes-minimum
META_GRAPH_VERSION=v21.0
META_APP_ID=
META_APP_SECRET=
META_EMBEDDED_SIGNUP_REDIRECT_URI=

# Test mode: redirect all notification emails to nome.cognome@romeolab.it
NOTIFICATION_TEST_MODE=true
NOTIFICATION_TEST_EMAIL=dariolarosa@hotmail.com
